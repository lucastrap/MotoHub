# ─────────────────────────────────────────────────────────────
# MotoTrack   modèle de configuration
# Copier ce fichier en `.env` et renseigner les valeurs.
# `.env` est exclu du versionnement (cf. .gitignore) : ne jamais y committer de secret.
# ─────────────────────────────────────────────────────────────

# Base de données PostgreSQL.
# En local (docker-compose.yml) : la valeur ci-dessous fonctionne telle quelle.
# En production Supabase : utiliser l'URL "pooler" (PgBouncer, port 6543), compatible
# avec l'exécution serverless de Vercel.
DATABASE_URL="postgresql://mototrack:mototrack_password@localhost:5432/mototrack_db?schema=public"

# Connexion directe (port 5432), utilisée uniquement par Prisma Migrate : le pooler
# ne supporte pas les migrations. Requise par la configuration Supabase
# (branche `chore/supabase-config`) ; inutile en local.
# DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Secret de signature des JWT (HS256). 32 caractères minimum.
# L'application refuse de démarrer si cette variable est absente (fail-fast,
# cf. getJwtSecretKey() dans src/lib/auth.ts).
# Générer une valeur : openssl rand -base64 32
JWT_SECRET="remplacer-par-un-secret-de-32-caracteres-minimum"

# URL publique de l'application.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Niveau de journalisation Winston (optionnel   défaut : info).
# Valeurs : error | warn | info | http | verbose | debug | silly
LOG_LEVEL="info"
