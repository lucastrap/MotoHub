---
title: "S3b · Organisation technique & flux de dépendances   MotoTrack (§4.1)"
---
flowchart TB
    NAV(["Navigateur"])

    subgraph APP["src/app/   transport HTTP & rendu (Next.js App Router)"]
        MW["middleware.ts   Edge Runtime<br/>matcher : /dashboard · /garage · /maintenance · /news · /pieces · /weather · /login · /register"]
        PROT["Pages protégées<br/>dashboard · garage · maintenance · news · pieces · weather<br/>jeton absent → /login"]
        AUTHP["Pages d'auth<br/>(auth)/login · (auth)/register<br/>déjà connecté → /dashboard"]
        PUB["Pages publiques (non matchées   hors garde)<br/>/ accueil (scène Three.js) · offline"]
        WIZ["garage/new/wizardLogic.ts<br/>logique de saisie"]
        API["Route handlers   api/auth · api/motorcycles · api/maintenances<br/>api/motorcycle-models · api/news · api/health<br/>hors matcher du middleware → auth par handler (cookie + verifyAuth)"]
    end

    subgraph CMP["src/components/   présentation (montés dans app/layout.tsx)"]
        direction LR
        C_LAYOUT["layout/AppLayout.tsx"]
        C_UI["ui/   button · input · label"]
        C_3D["3d/MotorcycleScene.tsx"]
        C_PWA["pwa/   OfflineGuard · ServiceWorkerRegister"]
    end

    subgraph LIB["src/lib/   modules transverses réutilisables (testables isolément)"]
        direction LR
        L_AUTH["auth.ts"]
        L_RATE["rateLimit.ts"]
        L_PLATE["formatPlate.ts"]
        L_LOG["logger.ts"]
        L_PRISMA["prisma.ts"]
        L_UTILS["utils.ts"]
        L_SCHED["maintenance/schedule.ts"]
    end

    subgraph DATA["Accès aux données & persistance"]
        PRISMA["Prisma Client   ORM"]
        DB[("PostgreSQL<br/>contraintes · index · onDelete: Cascade")]
        PRISMA -->|"SQL"| DB
    end

    subgraph EXT["Systèmes externes"]
        RSS["RSS Google News"]
        NHTSA["NHTSA vPIC"]
        METEO["Open-Meteo · Nominatim"]
    end

    subgraph PWACLIENT["Couche client   PWA (navigateur uniquement)"]
        SW["Service Worker   public/sw.js + Workbox<br/>précache · stratégie offline"]
    end

    %% Navigation : seules les pages du matcher traversent le middleware
    NAV --> MW
    MW --> PROT
    MW --> AUTHP
    NAV -->|"pages non matchées : contournent le middleware"| PUB

    %% Fetch côté navigateur (JS des pages) vers l'API   ne passe pas par le middleware
    PROT -->|"fetch /api/* (news → /api/news · pieces → /api/motorcycles)"| API
    AUTHP -->|"POST /api/auth/*"| API

    %% Les pages composent les composants ; l'accueil monte la scène 3D
    PROT --> CMP
    AUTHP --> CMP
    PUB --> CMP

    PROT --> WIZ

    %% Dépendances internes
    API --> LIB
    CMP -.->|"cn (lib/utils)   helper pur autorisé"| LIB
    LIB -->|"via lib/prisma.ts (singleton)"| PRISMA

    %% Appels aux systèmes externes
    API -->|"côté serveur"| RSS
    API -->|"côté serveur"| NHTSA
    PROT -->|"weather → côté client"| METEO

    %% Branche PWA côté client
    NAV -.->|"enregistre /sw.js (ServiceWorkerRegister)"| SW
    SW -.->|"sert le cache hors-ligne"| NAV
    C_PWA -.->|"navigator hors-ligne → /offline (OfflineGuard)"| PUB

    %% Interdits vérifiés dans le code
    N1["interdit   vérifié : aucun import de app/ dans lib/"]
    N1 -. règle .-> LIB
    CMP -. "interdit : jamais Prisma" .-x PRISMA

