# ─────────────────────────────────────────────────────────────
# Base de données — Supabase (PostgreSQL managé)
# ─────────────────────────────────────────────────────────────
# URL "pooler" (PgBouncer, port 6543) : utilisée par l'application à l'exécution.
# Recommandée en environnement serverless (Vercel) pour limiter les connexions.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# URL directe (port 5432) : utilisée par Prisma Migrate pour appliquer les migrations.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────────────────────
# Authentification
# ─────────────────────────────────────────────────────────────
# Secret de signature des JWT (HS256) — 32 caractères minimum.
JWT_SECRET="remplacer-par-une-chaine-aleatoire-de-32-caracteres-minimum"

# ─────────────────────────────────────────────────────────────
# Divers
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
LOG_LEVEL="info"

# En développement local (Docker), on peut faire pointer les deux URL
# vers la base locale :
# DATABASE_URL="postgresql://mototrack:mototrack_password@localhost:5432/mototrack_db?schema=public"
# DIRECT_URL="postgresql://mototrack:mototrack_password@localhost:5432/mototrack_db?schema=public"
